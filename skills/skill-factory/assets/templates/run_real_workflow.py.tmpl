from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run real {{TOOL_NAME}} workflow.")
    parser.add_argument("--species", default="human")
    parser.add_argument("--assembly", default="hg38")
    parser.add_argument("--chrom", default="chr19")
    parser.add_argument("--start", type=int, default=6_700_000)
    parser.add_argument("--end", type=int, default=6_732_768)
    parser.add_argument("--model", default=None, help="Model name or checkpoint path")
    parser.add_argument("--output-dir", default="output/{{ID}}")
    parser.add_argument("--output-prefix", default="{{ID}}_real_run")
    return parser.parse_args()


